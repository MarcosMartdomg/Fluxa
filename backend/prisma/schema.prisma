generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TriggerType {
  WEBHOOK
  SCHEDULE
  EVENT
}

enum ActionType {
  HTTP_REQUEST
  EMAIL
  DELAY
  CONDITION
  GOOGLE_SHEETS
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  projects    Project[]
  workflows   Workflow[]
  connections Connection[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Project {
  id          String     @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  workflows   Workflow[]
  canvas      ProjectCanvas?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model ProjectCanvas {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards     Json
  edges     Json
  updatedAt DateTime @updatedAt
}

model Workflow {
  id          String      @id @default(cuid())
  name        String
  description String?
  isActive    Boolean     @default(true)
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  projectId   String?
  project     Project?    @relation(fields: [projectId], references: [id])
  trigger     Trigger?
  actions     Action[]
  executions  Execution[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}


model Trigger {
  id         String      @id @default(cuid())
  type       TriggerType
  config     Json
  workflowId String      @unique
  workflow   Workflow    @relation(fields: [workflowId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Action {
  id         String     @id @default(cuid())
  name       String
  type       ActionType
  config     Json
  order      Int
  workflowId     String
  workflow       Workflow        @relation(fields: [workflowId], references: [id])
  stepExecutions StepExecution[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Execution {
  id         String          @id @default(cuid())
  status     ExecutionStatus @default(PENDING)
  payload    Json?
  workflowId String
  workflow       Workflow        @relation(fields: [workflowId], references: [id])
  logs           ExecutionLog[]
  stepExecutions StepExecution[]
  startedAt      DateTime        @default(now())
  finishedAt     DateTime?
}

model ExecutionLog {
  id          String    @id @default(cuid())
  level       String    @default("INFO")
  message     String
  meta        Json?
  executionId String
  execution   Execution @relation(fields: [executionId], references: [id])
  createdAt   DateTime  @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  subject   String
  message   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model StepExecution {
  id          String    @id @default(cuid())
  executionId String
  execution   Execution @relation(fields: [executionId], references: [id])
  actionId    String
  action      Action    @relation(fields: [actionId], references: [id])
  status      String    // COMPLETED, FAILED
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
}

model Connection {
  id           String   @id @default(cuid())
  providerId   String   // e.g. 'google', 'slack'
  name         String?  // User-defined name for this connection
  credentials  Json     // JSON with tokens/keys
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, providerId, name])
}
